# Agent logic
AGENT_COMMAND=python my_agent.py

# Marketplace registration
AGENT_CAPABILITY=translate
AGENT_NAME=My Translator Agent
AGENT_DESCRIPTION=Translates text between languages
AGENT_PRICE=10000000
AGENT_ENDPOINT=https://my-agent.com
AGENT_FINAL_TIMEOUT=1200
AGENT_SYNC_TIMEOUT=30

# Arguments schema (required by default; add :optional)
AGENT_ARG_text=string:Text to translate
AGENT_ARG_target_lang=string:Target language code (en, ru, de):optional

# TON wallet
AGENT_WALLET=EQ...
AGENT_WALLET_PK=...
AGENT_WALLET_SEED=

# Registry
REGISTRY_ADDRESS=EQ...

# Server
PORT=8080

# Payment
PAYMENT_TIMEOUT=300
ENFORCE_COMMENT_NONCE=true
REFUND_FEE_NANOTON=500000

# External APIs
TONCENTER_BASE_URL=https://toncenter.com/api/v3
TONCENTER_API_KEY=
TON_STORAGE_BASE_URL=https://mytonstorage.org
TON_STORAGE_SESSION=

# Local state
SIDECAR_STATE_PATH=.sidecar_state.json
SIDECAR_TX_DB_PATH=processed_txs.db
DOCS_PATH=docs.json
JOBS_TTL_SECONDS=3600
STORAGE_EXTEND_THRESHOLD_DAYS=7

# For MVP/dev mode. Set false only when real TON send is implemented.
SIDECAR_DRY_RUN=true
