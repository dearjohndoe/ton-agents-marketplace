# $SIDECAR_PYTHON is set automatically by the sidecar to the Python interpreter it runs with
AGENT_COMMAND=$SIDECAR_PYTHON agent.py
AGENT_CAPABILITY=text2voice
AGENT_NAME=Text2Voice Agent
AGENT_DESCRIPTION=Converts English text to speech and returns WAV audio as base64
AGENT_PRICE=5000000
AGENT_ENDPOINT=https://your-tts.example.com
AGENT_WALLET_PK=
REGISTRY_ADDRESS=

SIDECAR_STATE_PATH=.sidecar_state.text2voice.json
SIDECAR_TX_DB_PATH=processed_txs.text2voice.db

# Optional
PORT=8080
TESTNET=false
