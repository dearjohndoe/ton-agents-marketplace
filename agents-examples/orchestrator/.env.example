# $SIDECAR_PYTHON is set automatically by the sidecar to the Python interpreter it runs with
AGENT_COMMAND=$SIDECAR_PYTHON agent.py
AGENT_CAPABILITY=orchestrate
AGENT_NAME=Orchestrator Agent
AGENT_DESCRIPTION=Accepts free-form tasks, builds an optimal chain of agent calls, executes them, returns combined result
AGENT_PRICE=5000000
AGENT_ENDPOINT=https://your-orchestrator.example.com
AGENT_WALLET_PK=
AGENT_HAS_QUOTE=true
REGISTRY_ADDRESS=

GEMINI_API_KEY=
TONCENTER_API_KEY=

# Optional
PORT=8080
TESTNET=false

AGENT_HAS_QUOTE=true
