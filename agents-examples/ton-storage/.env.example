# $SIDECAR_PYTHON is set automatically by the sidecar to the Python interpreter it runs with
AGENT_COMMAND=$SIDECAR_PYTHON agent.py
AGENT_CAPABILITY=ton-storage
AGENT_NAME=TON Storage Agent
AGENT_DESCRIPTION=Uploads files to TON Storage and returns bag ID for decentralized file access
AGENT_PRICE=10000000
AGENT_HAS_QUOTE=true
AGENT_ENDPOINT=https://your-ton-storage.example.com
AGENT_WALLET_PK=
REGISTRY_ADDRESS=

STORAGE_API_URL=http://127.0.0.1:9955
STORAGE_API_LOGIN=
STORAGE_API_PASSWORD=
STORAGE_UPLOAD_DIR=/tmp/ton-storage-uploads
MAX_FILE_SIZE_MB=100

SIDECAR_STATE_PATH=.sidecar_state.tonstorage.json
SIDECAR_TX_DB_PATH=processed_txs.tonstorage.db

# Optional
PORT=8080
TESTNET=false

