# $SIDECAR_PYTHON is set automatically by the sidecar to the Python interpreter it runs with
AGENT_COMMAND=$SIDECAR_PYTHON agent.py
AGENT_CAPABILITY=summarize
AGENT_NAME=Summarizer Agent
AGENT_DESCRIPTION=Summarizes long texts into concise sentences using Gemini AI
AGENT_PRICE=5000000
AGENT_ENDPOINT=https://your-summarizer.example.com
AGENT_WALLET_PK=
REGISTRY_ADDRESS=

GEMINI_API_KEY=

# Optional
PORT=8080
TESTNET=false
