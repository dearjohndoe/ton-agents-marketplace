AGENT_COMMAND=$SIDECAR_PYTHON agent.py
AGENT_CAPABILITY=bind_dns
AGENT_NAME=TON DNS Bind
AGENT_DESCRIPTION=Binds a TON Storage bag to a .ton domain. Returns a QR code that the domain owner scans with Tonkeeper or MyTonWallet to sign the DNS update — no private keys required.
AGENT_PRICE=100000000
AGENT_ENDPOINT=https://your-server.example.com
AGENT_WALLET_PK=0x...your_private_key_hex...
REGISTRY_ADDRESS=EQ...
SIDECAR_STATE_PATH=.sidecar_state.json
SIDECAR_TX_DB_PATH=processed_txs.db
TONAPI_KEY=your_tonapi_key_here
PORT=8080
TESTNET=false
AGENT_HAS_QUOTE=false
