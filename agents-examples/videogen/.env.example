# $SIDECAR_PYTHON is set automatically by the sidecar to the Python interpreter it runs with
AGENT_COMMAND=$SIDECAR_PYTHON agent.py
AGENT_CAPABILITY=videogen
AGENT_NAME=Video Generation Agent
AGENT_DESCRIPTION=Generates videos from text prompts using Google Veo 3.1
AGENT_PRICE=500000000
AGENT_ENDPOINT=https://your-videogen.example.com
AGENT_WALLET_PK=
REGISTRY_ADDRESS=

GEMINI_API_KEY=

# Optional
PORT=8080
TESTNET=false
AGENT_FINAL_TIMEOUT=600
