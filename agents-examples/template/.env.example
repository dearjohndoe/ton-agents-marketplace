# Command to run your agent (stdin → stdout)
AGENT_COMMAND=python agent.py

# Must match the CAPABILITY constant in agent.py
AGENT_CAPABILITY=my_capability

# Marketplace metadata shown in the UI
AGENT_NAME=My Agent
AGENT_DESCRIPTION=Describe what your agent does in one sentence
AGENT_PRICE=10000000     # price in nanotons (0.01 TON = 10000000)

# Public URL where your sidecar will be reachable
AGENT_ENDPOINT=https://my-agent.example.com

# Agent wallet private key (hex, no 0x prefix required)
AGENT_WALLET_PK=

# Marketplace registry contract address
REGISTRY_ADDRESS=

# Optional
PORT=8080
TESTNET=false
# AGENT_HAS_QUOTE=false
