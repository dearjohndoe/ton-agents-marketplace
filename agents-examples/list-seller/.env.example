# $SIDECAR_PYTHON is set automatically by the sidecar to the Python interpreter it runs with
AGENT_COMMAND=$SIDECAR_PYTHON agent.py
AGENT_CAPABILITY=list-seller
AGENT_NAME=List Seller Agent
AGENT_DESCRIPTION=Sells items from a hardcoded inventory list (one per call), supports multiple SKUs.
AGENT_ENDPOINT=https://your-list-seller.example.com
AGENT_WALLET_PK=
REGISTRY_ADDRESS=

# --- Pricing & inventory ---
# Multi-SKU mode (recommended): each SKU has its own tokens-<sku>.txt file.
# Format: sku:stock:<price_spec>  where price_spec ∈ {ton=<nanoton>, usd=<micro_usd>}
#
# Stock = "infinite" — sidecar does NOT track remaining items. Agent is the
# source of truth: it pops a line from tokens-<sku>.txt on each invoke and
# returns {"error":"out_of_stock"} when the file is empty (sidecar then
# refunds automatically). This avoids dual-bookkeeping between the file and
# sidecar's stock.db. Pre-check in /quote is therefore "always pass" — users
# learn about empty inventory only after payment + refund.
AGENT_SKUS=basic:infinite:ton=100000000,premium:infinite:ton=500000000
AGENT_SKU_TITLES=basic=Basic key,premium=Premium key

# Включить quote-флоу: фронт обязан сначала дёрнуть POST /quote.
# Агент в mode=quote проверяет, что файл токенов не пуст, и только тогда
# возвращает цену. Пустой инвентарь → 500 на /quote → пользователь не платит.
# Это best-effort гейт (peek без pop, остаётся узкая гонка на последних
# позициях), но он закрывает основной кейс «инвентарь закончился — платить
# не нужно».
AGENT_HAS_QUOTE=true

# Legacy single-SKU mode (use only if AGENT_SKUS is empty):
# AGENT_PRICE=100000000
# AGENT_PRICE_USD=
# AGENT_STOCK= (leave empty for infinite)

# --- list-seller specific ---
# Path template; <sku> is substituted at runtime by the agent.
# Keep tokens OUTSIDE the repo to avoid accidental commits.
TOKENS_FILE_PATH=/var/lib/list-seller/tokens-<sku>.txt
# Optional, default is log.txt next to agent.py
LOG_FILE_PATH=/var/log/list-seller/log.txt

# --- Sidecar state ---
SIDECAR_STATE_PATH=.sidecar_state.list-seller.json
SIDECAR_TX_DB_PATH=processed_txs.list-seller.db

# Optional
PORT=8080
TESTNET=true
