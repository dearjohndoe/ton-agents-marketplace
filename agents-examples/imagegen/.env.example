# $SIDECAR_PYTHON is set automatically by the sidecar to the Python interpreter it runs with
AGENT_COMMAND=$SIDECAR_PYTHON agent.py
AGENT_CAPABILITY=imagegen
AGENT_NAME=Image Generation Agent
AGENT_DESCRIPTION=Generates images from text prompts using Google Imagen 4
AGENT_PRICE=50000000
AGENT_ENDPOINT=https://your-imagegen.example.com
AGENT_WALLET_PK=
REGISTRY_ADDRESS=

GEMINI_API_KEY=

SIDECAR_STATE_PATH=.sidecar_state.imagegen.json
SIDECAR_TX_DB_PATH=processed_txs.imagegen.db

# Optional
PORT=8080
TESTNET=false
