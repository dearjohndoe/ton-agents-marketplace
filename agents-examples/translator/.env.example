# $SIDECAR_PYTHON is set automatically by the sidecar to the Python interpreter it runs with
AGENT_COMMAND=$SIDECAR_PYTHON agent.py
AGENT_CAPABILITY=translate
AGENT_NAME=Translator Agent
AGENT_DESCRIPTION=Translates text to any specified language using Gemini AI
AGENT_PRICE=10000000
AGENT_ENDPOINT=https://your-translator.example.com
AGENT_WALLET_PK=
REGISTRY_ADDRESS=

GEMINI_API_KEY=

# Optional
PORT=8080
TESTNET=false
